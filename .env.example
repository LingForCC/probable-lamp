# ── RingCentral OAuth credentials ─────────────────────────────────────────────
# Register an app at https://developer.ringcentral.com (REST API App).
# Enable scopes: Team Messaging, WebSocket Subscriptions, Read Accounts.
# Set the redirect URI in the app console to exactly RC_REDIRECT_URI.
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_REDIRECT_URI=http://localhost:4173/auth/callback

# sandbox | production
RC_SERVER=sandbox

# mock | real — when "mock", the app uses an in-memory fake backend so it runs
# with zero credentials and no network. Used by tests and for local demos.
RC_API_MODE=mock
