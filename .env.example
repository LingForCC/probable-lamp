# ── RingCentral JWT (server auth) ────────────────────────────────────────────
# Register an app at https://developer.ringcentral.com (REST API App, server-only).
# Enable scopes: Team Messaging, WebSocket Subscriptions, Read Accounts.
# Generate a JWT for the app in the developer console and paste it here.
# The JWT is exchanged for a short-lived access token at startup (jwt-bearer grant).
RC_JWT=

# Optional: client id/secret are no longer required for auth but may be set for
# app identity / future use.
RC_CLIENT_ID=
RC_CLIENT_SECRET=

# sandbox | production
RC_SERVER=sandbox

# mock | real — when "mock", the app uses an in-memory fake backend so it runs
# with zero credentials and no network. Used by tests and for local demos.
RC_API_MODE=mock
